<%- include('_header', { actionsPartial: '_image-actions' }) %>

    <div class="image-detail">
      <img src="<%= imageSrc %>" alt="Uploaded image <%= id %>" class="image-detail__img">
    </div>

    <div id="confirm-delete" class="modal-backdrop">
      <div class="modal">
        <p class="modal__body">Delete this image? This cannot be undone.</p>
        <div class="modal__actions">
          <a href="#" class="btn">Cancel</a>
          <form method="POST" action="/image/<%= id %>/delete" class="modal__form">
            <button type="submit" class="btn btn--danger">Delete</button>
          </form>
        </div>
      </div>
    </div>

<%- include('_footer') %>
